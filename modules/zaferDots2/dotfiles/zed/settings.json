// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "vim_mode": false,
  "language_models": {
    "opencode": {
      "show_go_models": true
    }
  },
  "cli_default_open_behavior": "existing_window",
  "git_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "left"
  },
  "agent": {
    "default_model": {
      "provider": "opencode",
      "model": "free/nemotron-3-super-free",
      "enable_thinking": false
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
}
